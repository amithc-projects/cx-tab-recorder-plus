{
  "manifest_version": 3,
  "name": "OmniCapt",
  "version": "4.0",
  "description": "Capture screenshots, record browser tabs, annotate, and batch-capture multiple URLs or open tabs.",
  "permissions": ["activeTab", "tabs", "tabGroups", "debugger", "scripting", "storage", "tabCapture", "offscreen", "downloads", "notifications", "clipboardWrite", "clipboardRead", "contextMenus"],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OmniCapt",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+Q", "mac": "Alt+Shift+Q" },
      "description": "Open Recorder Popup"
    },
    "stop-recording": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "Stop Recording and Save"
    },
    "pause-recording": {
      "suggested_key": { "default": "Alt+Shift+P", "mac": "Alt+Shift+P" },
      "description": "Pause / Resume Recording"
    },
    "annotate": {
      "suggested_key": { "default": "Alt+Shift+A", "mac": "Alt+Shift+A" },
      "description": "Open annotation toolbar on current page"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}